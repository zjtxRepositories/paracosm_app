source 'https://cdn.cocoapods.org/'
source 'https://github.com/CocoaPods/Specs.git'

platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

def strip_bitcode(binary_path)
  return unless File.exist?(binary_path)

  bitcode_strip = `xcrun --find bitcode_strip`.strip
  Pod::UI.puts "Stripping bitcode from #{binary_path}"
  unless system(bitcode_strip, binary_path, '-r', '-o', binary_path)
    raise "Failed to strip bitcode from #{binary_path}"
  end
end

post_install do |installer|
  x86_only_simulator_targets = [
    'rongcloud_call_wrapper_plugin',
    'RongCloudRTC',
    'RongWrapperLog'
  ]

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # iOS 最低版本
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # ⚠️ 关闭 Bitcode，解决 RongWrapperLog.framework incomplete bitcode
      config.build_settings['ENABLE_BITCODE'] = 'NO'

      # 预处理宏
      definitions = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
      definitions = [definitions] unless definitions.is_a?(Array)
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = definitions | [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
        'PERMISSION_MICROPHONE=1',
      ]

      # 排除模拟器架构
      if x86_only_simulator_targets.include?(target.name)
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64 i386'
      end

      # libwebp 警告处理
      if target.name == 'libwebp'
        config.build_settings['GCC_WARN_UNINITIALIZED_AUTOS'] = 'NO'
        cflags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
        cflags = [cflags] unless cflags.is_a?(Array)
        config.build_settings['OTHER_CFLAGS'] = cflags | ['-Wno-conditional-uninitialized']
      end
    end

    # bdk_flutter 特殊路径处理
    if target.name == 'bdk_flutter'
      target.shell_script_build_phases.each do |phase|
        next if phase.shell_script.include?('$HOME/.cargo/bin')
        phase.shell_script = "export PATH=\"$HOME/.cargo/bin:$PATH\"\n#{phase.shell_script}"
      end
    end
  end

  strip_bitcode(File.join(
    installer.sandbox.root.to_s,
    'RongWrapperLog/RongWrapperLog/RongWrapperLog.xcframework/ios-arm64_armv7/RongWrapperLog.framework/RongWrapperLog'
  ))
end
